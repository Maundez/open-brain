# ============================================================
# Open Brain Web App — Production Environment Variables
# ============================================================
# Copy this file to .env.production on the NUC and fill in
# the real values. Never commit .env.production to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://iwyofenfguyrzgqwytse.supabase.co

# Service role key — server-side only, bypasses RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── OpenRouter ───────────────────────────────────────────────
# Used server-side for semantic search embeddings.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── NextAuth ─────────────────────────────────────────────────
# Must match the public URL of the app (no trailing slash).
NEXTAUTH_URL=https://brain.maundez.uk

# Random secret for signing JWT session cookies.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# ── Microsoft Entra ID (Azure AD) ────────────────────────────
# From your Azure App Registration (DTS Solutions tenant).
AZURE_AD_CLIENT_ID=your-azure-client-id-here
AZURE_AD_CLIENT_SECRET=your-azure-client-secret-here
AZURE_AD_TENANT_ID=your-azure-tenant-id-here
